# Copy this file to .env.local and fill in your real values for local dev.
# On Vercel, set these in Project Settings -> Environment Variables instead.

ANTHROPIC_API_KEY=sk-ant-paste-your-key-here

# From https://developer.spotify.com/dashboard (create an app, then "View settings")
SPOTIFY_CLIENT_ID=paste-your-spotify-client-id
SPOTIFY_CLIENT_SECRET=paste-your-spotify-client-secret
